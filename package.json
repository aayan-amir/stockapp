{
  "name": "stock-management-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "env:ensure": "node scripts/copy-env.js",
    "dev": "npm run env:ensure && next dev",
    "build": "npm run env:ensure && npx prisma generate && next build",
    "start": "npm run db:init && next start -H 0.0.0.0",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:init": "npm run env:ensure && node scripts/db-init.js",
    "setup": "npm run env:ensure && npm install && npm run db:init"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "next": "15.3.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "prisma": "^5.10.0",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1"
  }
}
